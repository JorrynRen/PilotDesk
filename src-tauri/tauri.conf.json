{
  "productName": "PilotDesk",
  "version": "0.1.0",
  "identifier": "com.pilotdesk.app",
  "build": {
    "beforeBuildCommand": "npm run build",
    "devUrl": "http://127.0.0.1:1420",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "PilotDesk",
        "width": 1404,
        "height": 820,
        "minWidth": 1404,
        "minHeight": 820,
        "decorations": false,
        "shadow": false,
        "transparent": false,
        "resizable": true
      }
    ],
    "security": {
      "csp": "default-src 'self'; script-src 'self' 'unsafe-inline' 'unsafe-eval' http://127.0.0.1:1420 http://localhost:1420; style-src 'self' 'unsafe-inline' http://127.0.0.1:1420; img-src 'self' data: https:; connect-src 'self' ws://localhost:* http://localhost:* http://127.0.0.1:1420"
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.ico",
      "icons/icon.png"
    ],
    "resources": [
      "resources/agents/*",
      "resources/icons/*",
      "resources/assets/*"
    ]
  }
}